<view class="page">
  <view class="profile-header">
    <view class="profile-bg"></view>
    <view class="profile-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <text class="nickname">{{userInfo.nickName || '未登录'}}</text>
      <view class="admin-badge" wx:if="{{isAdmin}}">
        <text class="admin-text">管理员</text>
      </view>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="goMyApplications">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的申请</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="showAdminLogin" wx:if="{{!isAdmin}}">
      <text class="menu-icon">🔑</text>
      <text class="menu-text">管理员验证</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAdmin" wx:if="{{isAdmin}}">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">管理后台</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="section-title" style="padding: 0 24rpx; margin-top: 20rpx;">我的申请记录</view>

  <view class="applications-list" wx:if="{{applications.length > 0}}" style="padding: 0 24rpx;">
    <view class="application-item card" wx:for="{{applications}}" wx:key="_id" bindtap="goPetDetail" data-id="{{item.petId}}">
      <view class="app-header">
        <text class="app-pet-name">{{item.petName}}</text>
        <status-tag status="{{item.status}}" type="application"></status-tag>
      </view>
      <text class="app-time">{{item.formattedTime}}</text>
    </view>
  </view>

  <empty-state wx:if="{{applications.length === 0 && !loadingApps}}" icon="📋" message="暂无申请记录"></empty-state>

  <view class="bottom-space"></view>
</view>
