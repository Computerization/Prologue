.photo-swiper {
  width: 100%;
  height: 500rpx;
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 500rpx;
}

.info-card {
  background: #fff;
  margin: -40rpx 24rpx 20rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.pet-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-tag {
  display: flex;
  align-items: center;
  background: #FFF8F0;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.tag-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #666;
}

.desc-card {
  margin: 0 24rpx 160rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.adopt-btn {
  width: 100%;
  margin: 0;
}

.disabled-btn {
  width: 100%;
  margin: 0;
  background: #f0f0f0;
  color: #999;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 32rpx;
  text-align: center;
}

.admin-actions {
  display: flex;
  margin-top: 16rpx;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  font-size: 26rpx;
  margin: 0;
}
