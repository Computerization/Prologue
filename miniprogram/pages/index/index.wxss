.header {
  padding: 20rpx 0 12rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 4rpx 12rpx;
}

.filter-tabs {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 0 24rpx;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.3s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #FF8C42, #FF6B6B);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 66, 0.3);
}

.pet-list {
  padding-bottom: 20rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8C42, #FF6B6B);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
