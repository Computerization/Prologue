.admin-header {
  padding: 16rpx 0 24rpx;
}

.admin-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #FF8C42;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.add-btn {
  background: linear-gradient(135deg, #FF8C42, #FF6B6B);
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  margin: 0;
  line-height: 1.4;
}

.add-btn::after {
  border: none;
}

.admin-pet-item {
  margin-bottom: 16rpx;
}

.admin-pet-info {
  display: flex;
  align-items: center;
}

.admin-pet-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.admin-pet-text {
  flex: 1;
  overflow: hidden;
}

.admin-pet-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-pet-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.admin-pet-breed {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.admin-pet-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-link {
  font-size: 26rpx;
  color: #FF8C42;
}

.action-link.danger {
  color: #ff4757;
}

.view-all {
  font-size: 26rpx;
  color: #FF8C42;
}

.app-item {
  margin-bottom: 16rpx;
}

.app-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.app-pet-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.app-user {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.app-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.approve-btn {
  flex: 1;
  background: #e8f8ee;
  color: #2ed573;
  font-size: 26rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  text-align: center;
  margin: 0;
  line-height: 1.4;
}

.approve-btn::after {
  border: none;
}

.reject-btn {
  flex: 1;
  background: #ffe8ea;
  color: #ff4757;
  font-size: 26rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  text-align: center;
  margin: 0;
  line-height: 1.4;
}

.reject-btn::after {
  border: none;
}
