.form-card {
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #ff4757;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #FFF8F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  line-height: 1.6;
}

.species-picker, .gender-picker {
  display: flex;
  gap: 16rpx;
}

.species-option, .gender-option {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background: #FFF8F0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.species-option.active, .gender-option.active {
  background: linear-gradient(135deg, #FF8C42, #FF6B6B);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 66, 0.3);
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #FFF8F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 200rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.photo-preview {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.photo-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 22rpx;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: #FFF8F0;
}

.photo-add-icon {
  font-size: 56rpx;
  color: #ccc;
  line-height: 1;
}

.photo-add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.submit-btn {
  margin-bottom: 40rpx;
}
